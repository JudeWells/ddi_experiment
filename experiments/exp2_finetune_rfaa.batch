#!/bin/bash
#SBATCH --job-name=ddi_exp2b_rfaa
#SBATCH --nodes=1
#SBATCH --gpus-per-node=4
#SBATCH --ntasks-per-node=4
#SBATCH --cpus-per-task=8
#SBATCH --time=48:00:00
#SBATCH --output=/projects/u6bz/jude/ddi_experiment/logs/exp2_finetune_rfaa_%j.out
#SBATCH --error=/projects/u6bz/jude/ddi_experiment/logs/exp2_finetune_rfaa_%j.err

# Experiment 2B: Fine-tuning - RFAA
# Fine-tune DDI-pretrained model on PDB multimers

set -e

SEED=${1:-42}
PROJECT_DIR="/projects/u6bz/jude/ddi_experiment"
CONFIG="${PROJECT_DIR}/configs/finetune.yaml"

PRETRAIN_DIR="${PROJECT_DIR}/outputs/rfaa"
PRETRAINED_MODEL=$(find ${PRETRAIN_DIR} -name "best_model.pt" -path "*ddi_pretrain_seed${SEED}*" | head -1)

if [ -z "${PRETRAINED_MODEL}" ]; then
    echo "ERROR: Pretrained model not found for seed ${SEED}"
    echo "Please run exp2_ddi_pretrain_rfaa.batch first"
    exit 1
fi

echo "=========================================="
echo "Experiment 2B: Fine-tuning - RFAA"
echo "Seed: ${SEED}"
echo "Pretrained: ${PRETRAINED_MODEL}"
echo "Start time: $(date)"
echo "=========================================="

module load conda 2>/dev/null || true
source "$(conda info --base)/etc/profile.d/conda.sh"
conda activate ddi_experiment

export MASTER_ADDR=$(hostname)
export MASTER_PORT=29506
export WORLD_SIZE=4

torchrun \
    --nproc_per_node=4 \
    --master_addr=${MASTER_ADDR} \
    --master_port=${MASTER_PORT} \
    ${PROJECT_DIR}/scripts/train_rfaa.py \
    --config ${CONFIG} \
    --experiment finetune \
    --seed ${SEED} \
    --pretrained ${PRETRAINED_MODEL}

echo "=========================================="
echo "Experiment completed at: $(date)"
echo "=========================================="
