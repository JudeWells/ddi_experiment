#!/bin/bash
#SBATCH --job-name=ddi_exp2a_ptx
#SBATCH --nodes=1
#SBATCH --gpus-per-node=4
#SBATCH --ntasks-per-node=4
#SBATCH --cpus-per-task=8
#SBATCH --time=96:00:00
#SBATCH --output=/projects/u6bz/jude/ddi_experiment/logs/exp2_ddi_pretrain_protenix_%j.out
#SBATCH --error=/projects/u6bz/jude/ddi_experiment/logs/exp2_ddi_pretrain_protenix_%j.err

# Experiment 2A: DDI Pre-training - Protenix
# Pre-train on DDI pairs (pLDDT > 70)

set -e

SEED=${1:-42}
PROJECT_DIR="/projects/u6bz/jude/ddi_experiment"
CONFIG="${PROJECT_DIR}/configs/ddi_pretrain.yaml"

echo "=========================================="
echo "Experiment 2A: DDI Pre-training - Protenix"
echo "Seed: ${SEED}"
echo "Start time: $(date)"
echo "=========================================="

module load conda 2>/dev/null || true
source "$(conda info --base)/etc/profile.d/conda.sh"
conda activate ddi_experiment

export MASTER_ADDR=$(hostname)
export MASTER_PORT=29507
export WORLD_SIZE=4

torchrun \
    --nproc_per_node=4 \
    --master_addr=${MASTER_ADDR} \
    --master_port=${MASTER_PORT} \
    ${PROJECT_DIR}/scripts/train_protenix.py \
    --config ${CONFIG} \
    --experiment ddi_pretrain \
    --seed ${SEED}

echo "=========================================="
echo "Experiment completed at: $(date)"
echo "=========================================="
